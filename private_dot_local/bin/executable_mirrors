#! /bin/bash

TMPFILE="$(mktemp)"

rate-mirrors --save=$TMPFILE arch
# reflector \
# 	--save=$TMPFILE \
# 	--country 'United States' \
# 	--age 24 \
# 	--protocol https \
# 	--sort rate

sudo mv /etc/pacman.d/mirrorlist /etc/pacman.d/mirrorlist-backup
sudo install -m 644 -o root -g root "$TMPFILE" /etc/pacman.d/mirrorlist
rm -f "$TMPFILE"
